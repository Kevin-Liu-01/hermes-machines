# Dedalus Cloud Services. The same key provisions machines (dcs.dedaluslabs.ai)
# and authenticates LLM inference (api.dedaluslabs.ai/v1, OpenAI-compatible),
# so Hermes routes 200+ models without a second key.
DEDALUS_API_KEY=dsk-live-replace-me

# Optional overrides. Defaults match the Dedalus production endpoints.
DEDALUS_BASE_URL=https://dcs.dedaluslabs.ai
DEDALUS_CHAT_BASE_URL=https://api.dedaluslabs.ai/v1

# Default model. Any Dedalus-routable slug works — see
# https://api.dedaluslabs.ai/v1/models for the full catalog.
# Examples: anthropic/claude-sonnet-4-6, openai/gpt-5, google/gemini-2.5-pro, deepseek/deepseek-v3
HERMES_MODEL=anthropic/claude-sonnet-4-6

# Machine sizing. Dev ceiling is 6144 MiB memory.
HERMES_VCPU=1
HERMES_MEMORY_MIB=2048
HERMES_STORAGE_GIB=10

# Cursor SDK API key (optional but required to use the cursor_agent MCP tool).
# Get one at https://cursor.com/dashboard/integrations or from Team Settings.
# When unset, the rest of the agent works fine; only delegating code work to a
# Cursor agent will fail with a clear error.
CURSOR_API_KEY=cursor_replace_me
