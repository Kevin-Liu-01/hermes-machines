# Hermes API server endpoint and bearer token (printed by `npm run deploy`).
# These are server-only — never NEXT_PUBLIC_* — so the bearer token never reaches the browser.
HERMES_API_URL=https://your-machine-preview.dedaluslabs.ai/v1
HERMES_API_KEY=hp-replace-me

# Default model name passed to the API. Hermes API ignores this on its own
# input but echoes it back in the response, so any string works.
HERMES_MODEL=hermes-agent
